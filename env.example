# Local Configuration
PORT=5000

# PostgreSQL Database (Local)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sql_class_2_db

# Render Configuration (Mandatory for Deployment)
# Copy the 'Internal Database URL' from your Render Database dashboard
DATABASE_URL=

# Authentication
# Generate a strong secret locally with: 
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRES_IN=1h
